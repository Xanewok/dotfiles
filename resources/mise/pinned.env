# Pinned mise release. Fill from a trusted machine: a version + its sha256 from that
# release's SHASUMS256.txt (https://github.com/jdx/mise/releases). While REPLACE_ME,
# linux-mise.sh skips mise with a warning (a fresh `./install.sh dev` never fails).

MISE_VERSION=REPLACE_ME
MISE_SHA256_X64=REPLACE_ME
MISE_SHA256_ARM64=REPLACE_ME
