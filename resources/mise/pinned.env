# Pinned mise release — verified once, bumped deliberately.
#
# Fill these from a trusted machine:
#   1. Pick a version:  https://github.com/jdx/mise/releases
#   2. Get the sha256 from that release's SHASUMS256.txt (or `sha256sum` the asset)
#   3. Confirm the asset filename matches the URL template in scripts/linux-mise.sh
#      (e.g. mise-vX.Y.Z-linux-x64 / -arm64; switch to the -musl variant there for
#       a fully static binary if a distro's glibc is too old)
#
# Until real values are set, scripts/linux-mise.sh skips mise with a warning
# (so a fresh `./install.sh dev` never fails just because this isn't filled in yet).

MISE_VERSION=REPLACE_ME
MISE_SHA256_X64=REPLACE_ME
MISE_SHA256_ARM64=REPLACE_ME
