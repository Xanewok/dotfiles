[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[color]
	ui = auto

# delta: syntax-highlighted, navigable diffs. The binary is `delta` on both brew and
# Debian's git-delta package. No theme set here yet, so it uses delta's default.
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
