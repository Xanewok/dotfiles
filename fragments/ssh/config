# Native Secure Enclave SSH keys on macOS 26+ (Tahoe). Apple's stock ssh can sign with
# a key held in the Secure Enclave, gated by Touch ID, through the built-in provider at
# /usr/lib/ssh-keychain.dylib — hardware-bound, non-exportable, no dongle, no third-party
# agent. SecurityKeyProvider only tells ssh HOW to sign an enclave key; ssh then finds
# the key itself at the default path ~/.ssh/id_ecdsa_sk, so there is no per-machine
# IdentityFile to hardcode here and this fragment is identical on every Mac. The
# `Match exec` gate applies it ONLY where the provider file exists (macOS Tahoe), so on
# Linux and older macOS `test -f` fails and nothing here takes effect.
#
# The key is per-device (like any private key) and is NOT provisioned here. Once per Mac:
#   sc_auth create-ctk-identity -l ssh -k p-256-ne -t bio               # enclave key (Touch ID)
#   ssh-keygen -w /usr/lib/ssh-keychain.dylib -K -N ""                  # writes id_ecdsa_sk_rk[.pub]
#   mv ~/.ssh/id_ecdsa_sk_rk ~/.ssh/id_ecdsa_sk                         # default name -> ssh auto-finds it
#   mv ~/.ssh/id_ecdsa_sk_rk.pub ~/.ssh/id_ecdsa_sk.pub
#   pbcopy < ~/.ssh/id_ecdsa_sk.pub                                     # add to GitHub / servers
# OpenSSH prompts for a PIN even though the key is biometric — just press Enter.
# Guide: https://gist.github.com/arianvp/5f59f1783e3eaf1a2d4cd8e952bb4acf
Match exec "test -f /usr/lib/ssh-keychain.dylib"
    SecurityKeyProvider /usr/lib/ssh-keychain.dylib
