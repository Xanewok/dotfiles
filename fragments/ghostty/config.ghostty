theme = dark:Builtin Solarized Dark,light:Builtin Solarized Light
font-family = Fira Code
# Breathing room so the prompt/output don't hug the window edges.
window-padding-x = 10
window-padding-y = 8
# Ghostty's default TERM (xterm-ghostty) has no terminfo on many remote hosts — keep it portable.
term = xterm-256color
