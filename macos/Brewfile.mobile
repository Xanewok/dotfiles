# Local Expo/React-Native builds: CocoaPods for ios/ pods, watchman for Metro.
# (mise/JDK come from the dev profile, which mobile requires — see profiles/mobile.sh.)
brew "cocoapods"
brew "watchman"
cask "android-studio", args: { adopt: true }
# NB: no android-commandlinetools cask — cmdline-tools come from the pinned zip
# (resources/android/pinned.env), so a non-admin builder can provision without brew.
