# gitk + git-gui via brew's Aqua Tcl/Tk — native windows, no XQuartz needed.
brew "git-gui"

# adopt: take over an identical manually-installed app instead of erroring on it.
cask "ghostty", args: { adopt: true }
cask "visual-studio-code", args: { adopt: true }
cask "1password", args: { adopt: true }
cask "secretive", args: { adopt: true }   # SSH keys in the Secure Enclave (Touch ID); wire IdentityAgent yourself
cask "font-fira-code", args: { adopt: true }
